# Browser login is enabled by default. Set WEB_AUTH_ENABLED=false only when the
# service is confined to a trusted private network; username/password may then
# be omitted. Generate long random values before exposing an authenticated service.
WEB_AUTH_ENABLED=true
WEB_USERNAME=scientist
WEB_PASSWORD=replace-with-a-long-random-password

# Required for A2A calls. This is independent of the browser password.
A2A_ENABLED=true
A2A_TOKEN=replace-with-an-independent-random-token
SANDBOX_WORKER_TOKEN=replace-with-a-third-independent-random-token
PACKAGE_WORKER_TOKEN=replace-with-a-fourth-independent-random-token
SCIENTIFIC_AGENT_PUBLIC_URL=http://127.0.0.1:8080
# Stable identity stamped into the knowledge volume. Use a distinct value for
# every deployment (for example, lab-prod and konrad-private); startup refuses a
# knowledge directory stamped for another identity.
EVIDENCE_BENCH_DEPLOYMENT_ID=local

# Optional host paths for durable bind-mounted state. Named Docker volumes are
# used when these are unset. Ensure UID 10001 can write the data directory.
EVIDENCE_BENCH_DATA_PATH=
EVIDENCE_BENCH_ENVIRONMENTS_PATH=
# Persistent Chromium profile and manually downloaded papers. The application
# mounts only its downloads subdirectory, read-only, at /browser-downloads.
EVIDENCE_BENCH_BROWSER_PATH=./.evidence-bench/browser

# OpenAI-compatible local model endpoints. From Docker Desktop/Linux Compose,
# host.docker.internal reaches services bound to the Docker host.
QWEN_BASE_URL=http://host.docker.internal:8000/v1
QWEN_MODEL=Qwen/Qwen3.6-27B
QWEN_API_KEY=
# Zero omits an explicit output ceiling so a compatible proxy can use all
# remaining context for reasoning and the final answer. Set a positive value to
# impose a client-side ceiling. Disable native schema only when the endpoint
# cannot combine JSON-schema decoding with thinking; local validation remains.
QWEN_MAX_TOKENS=0
# `inherit` is correct for gateways whose stable alias already enables maximum
# thinking. Use true/false only when a direct backend requires an explicit flag.
QWEN_ENABLE_THINKING=inherit
QWEN_NATIVE_JSON_SCHEMA=true
# An admitted request remains attached while the backend queues and evaluates it.
# This wall time is cancellable and does not cap output tokens or reasoning.
QWEN_REQUEST_TIMEOUT_SECONDS=21600
# Immediate capacity rejections (429/502/503/504 or a connection reset before
# output) wait with bounded backoff. Zero disables the extended wait window.
QWEN_CAPACITY_WAIT_SECONDS=21600
GEMMA_BASE_URL=http://host.docker.internal:8001/v1
GEMMA_MODEL=gemma4-12b-it
GEMMA_API_KEY=
GEMMA_MAX_TOKENS=0
GEMMA_ENABLE_THINKING=inherit
GEMMA_NATIVE_JSON_SCHEMA=true
GEMMA_REQUEST_TIMEOUT_SECONDS=21600
GEMMA_CAPACITY_WAIT_SECONDS=21600

# Optional read-only backend observability. These are trusted deployment-time
# origins, never caller-provided URLs. Evidence Bench reads only /metrics and,
# for llama.cpp Gemma, /slots; responses are bounded and redirects are refused.
# Leave empty when the backend does not expose compatible metrics.
QWEN_STATUS_BASE_URL=
GEMMA_STATUS_BASE_URL=
MODEL_STATUS_TIMEOUT_SECONDS=2
MODEL_STATUS_CACHE_SECONDS=3

# Optional retrieval integrations. Leave a key empty to disable its UI toggle.
CONTEXT7_API_KEY=
BRAVE_API_KEY=

# PubMed/PMC E-utilities identify the calling application with a real contact
# email. The API key is optional; without it Evidence Bench stays below 3 req/s.
SCIENTIFIC_AGENT_NCBI_EMAIL=researcher@example.org
SCIENTIFIC_AGENT_NCBI_TOOL=evidence_bench
SCIENTIFIC_AGENT_NCBI_API_KEY=

# Service-owned interactive browser. CDP passes through an internal fixed-target
# gateway and is never published. Chromium has public-only proxied egress and no
# application/worker/model network. Only passwordless noVNC is exposed; bind it
# to a trusted LAN/Tailnet address, never a public interface. When PUBLIC_URL is
# empty the WebUI uses its current hostname and BROWSER_NOVNC_PORT.
BROWSER_BIND_ADDRESS=127.0.0.1
BROWSER_NOVNC_PORT=6080
BROWSER_PUBLIC_URL=
BROWSER_GEOMETRY=1600x1000x24
# Usually leave these defaults. Root-squashed NFS deployments can run Chromium
# as the storage owner's host UID:GID and expose downloads read-only via 0755.
BROWSER_RUNTIME_USER=0:0
BROWSER_DOWNLOADS_MODE=2750

# Host exposure. The safe default is loopback only.
WEB_BIND_ADDRESS=127.0.0.1
WEB_PUBLISHED_PORT=8080

# Resource and repair budgets.
WEB_MAX_WORKERS=2
SCIENTIFIC_AGENT_MAX_RESEARCH_MODEL_TURNS=64
SCIENTIFIC_AGENT_MAX_RESEARCH_TOOL_CALLS=48
SCIENTIFIC_AGENT_MAX_REPEATED_TOOL_RESULTS=2
WEB_MAX_UPLOAD_BYTES=4294967296
MAX_REPAIR_ROUNDS=4
SCIENTIFIC_AGENT_MAX_WALL_SECONDS=300
SCIENTIFIC_AGENT_MAX_CODE_CALLS=12
SCIENTIFIC_AGENT_MAX_MEMORY_BYTES=8589934592
SCIENTIFIC_AGENT_MAX_PROCESSES=32
SCIENTIFIC_AGENT_MAX_FILE_BYTES=67108864
SCIENTIFIC_AGENT_MAX_OUTPUT_BYTES=268435456
SCIENTIFIC_AGENT_MAX_CODE_BYTES=131072
SCIENTIFIC_AGENT_MAX_PACKAGES_PER_CALL=24
SCIENTIFIC_AGENT_PACKAGE_TIMEOUT_SECONDS=900
# Logical-byte and filesystem-entry quotas include every retained immutable
# generation. A new generation is denied before copying its predecessor when
# cumulative capacity is insufficient, and failed staging trees are removed.
SCIENTIFIC_AGENT_MAX_ENVIRONMENT_BYTES=21474836480
SCIENTIFIC_AGENT_MAX_WORKSPACE_ENVIRONMENT_BYTES=42949672960
SCIENTIFIC_AGENT_MAX_TOTAL_ENVIRONMENT_BYTES=214748364800
SCIENTIFIC_AGENT_MAX_ENVIRONMENT_ENTRIES=250000
SCIENTIFIC_AGENT_MAX_WORKSPACE_ENVIRONMENT_ENTRIES=500000
SCIENTIFIC_AGENT_MAX_TOTAL_ENVIRONMENT_ENTRIES=2500000
