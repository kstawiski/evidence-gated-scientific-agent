# Required browser login. Generate long random values before exposing the service.
WEB_USERNAME=scientist
WEB_PASSWORD=replace-with-a-long-random-password

# Required for A2A calls. This is independent of the browser password.
A2A_ENABLED=true
A2A_TOKEN=replace-with-an-independent-random-token
SANDBOX_WORKER_TOKEN=replace-with-a-third-independent-random-token
PACKAGE_WORKER_TOKEN=replace-with-a-fourth-independent-random-token
SCIENTIFIC_AGENT_PUBLIC_URL=http://127.0.0.1:8080

# Optional host paths for durable bind-mounted state. Named Docker volumes are
# used when these are unset. Ensure UID 10001 can write the data directory.
EVIDENCE_BENCH_DATA_PATH=
EVIDENCE_BENCH_ENVIRONMENTS_PATH=

# OpenAI-compatible local model endpoints. From Docker Desktop/Linux Compose,
# host.docker.internal reaches services bound to the Docker host.
QWEN_BASE_URL=http://host.docker.internal:8000/v1
QWEN_MODEL=Qwen/Qwen3.6-27B
QWEN_API_KEY=
GEMMA_BASE_URL=http://host.docker.internal:8001/v1
GEMMA_MODEL=gemma4-12b-it
GEMMA_API_KEY=

# Optional retrieval/browser integrations. Leave a key empty to disable its UI toggle.
CONTEXT7_API_KEY=
BRAVE_API_KEY=
CHROME_DEVTOOLS_BROWSER_URL=http://host.docker.internal:9222

# Host exposure. The safe default is loopback only.
WEB_BIND_ADDRESS=127.0.0.1
WEB_PUBLISHED_PORT=8080

# Resource and repair budgets.
WEB_MAX_WORKERS=2
WEB_MAX_UPLOAD_BYTES=268435456
MAX_REPAIR_ROUNDS=1
SCIENTIFIC_AGENT_MAX_WALL_SECONDS=300
SCIENTIFIC_AGENT_MAX_CODE_CALLS=12
SCIENTIFIC_AGENT_MAX_MEMORY_BYTES=8589934592
SCIENTIFIC_AGENT_MAX_PROCESSES=32
SCIENTIFIC_AGENT_MAX_FILE_BYTES=67108864
SCIENTIFIC_AGENT_MAX_OUTPUT_BYTES=268435456
SCIENTIFIC_AGENT_MAX_CODE_BYTES=131072
SCIENTIFIC_AGENT_MAX_PACKAGES_PER_CALL=24
SCIENTIFIC_AGENT_PACKAGE_TIMEOUT_SECONDS=900
SCIENTIFIC_AGENT_MAX_ENVIRONMENT_BYTES=21474836480
